{
  "name": "twentytwentyfive-child-blocks",
  "version": "1.2.4",
  "description": "Custom blocks for the TwentyTwentyFive child theme.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "wp-scripts build --webpack-src-dir=blocks",
    "start": "wp-scripts start --webpack-src-dir=blocks",
    "prepackage": "npm run build",
    "package": "node scripts/package.js",
    "dist": "npm run build && npm run package"
  },
  "devDependencies": {
    "@wordpress/scripts": "^31.7.0"
  },
  "dependencies": {
    "@wordpress/html-entities": "^4.38.0"
  },
  "overrides": {
    "markdownlint-cli": {
      "minimatch": "3.1.4"
    },
    "copy-webpack-plugin": {
      "serialize-javascript": "7.0.5"
    },
    "webpack-dev-server": "5.2.3"
  }
}
